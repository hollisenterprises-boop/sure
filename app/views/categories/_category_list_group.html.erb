<%# locals: (title:, categories:, category_groups: nil, category_ids_with_transactions: nil, budget_categories_by_category_id: nil) %>
<% category_groups ||= Category::Group.for(categories) %>

<div class="rounded-xl bg-container-inset space-y-1 p-1">
  <div class="flex items-center gap-1.5 px-4 py-2 text-xs font-medium text-secondary uppercase">
    <p><%= title %></p>
    <span class="text-subdued">&middot;</span>
    <p><%= categories.count %></p>
  </div>

  <div class="shadow-border-xs rounded-lg bg-container">
    <div class="overflow-hidden rounded-lg" data-controller="categories-sortable">
      <% category_groups.each do |group| %>
        <div
          draggable="true"
          data-categories-sortable-target="section"
          data-section-key="<%= group.category.id %>"
          data-action="dragstart->categories-sortable#dragStart dragend->categories-sortable#dragEnd dragover->categories-sortable#dragOver drop->categories-sortable#drop keydown->categories-sortable#handleKeyDown"
          tabindex="0"
          aria-grabbed="false"
          class="[&:not(:last-child)]:border-b [&:not(:last-child)]:border-divider"
        >
          <%= render "categories/category",
                     category: group.category,
                     subcategories: group.subcategories,
                     has_transactions: category_ids_with_transactions&.key?(group.category.id),
                     budget_category: budget_categories_by_category_id&.dig(group.category.id),
                     draggable: true %>

          <% group.subcategories.each do |subcategory| %>
            <%= render "categories/category",
                       category: subcategory,
                       subcategories: [],
                       has_transactions: category_ids_with_transactions&.key?(subcategory.id),
                       budget_category: budget_categories_by_category_id&.dig(subcategory.id) %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
