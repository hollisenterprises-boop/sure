<%# locals: (category:, subcategories: nil, has_transactions: nil, budget_category: nil, draggable: false) %>
<% subcategories ||= category.subcategories.to_a %>
<% has_transactions = category.transactions.exists? if has_transactions.nil? %>

<div id="<%= dom_id(category) %>" class="flex items-center gap-3 px-4 pb-4 <%= "pt-4" unless category.subcategory? %> <%= "pb-4" unless subcategories.any? %> bg-container">
  <% if draggable %>
    <button type="button" class="cursor-grab active:cursor-grabbing shrink-0" aria-label="<%= t(".drag_handle") %>">
      <%= icon "grip-vertical", size: "sm" %>
    </button>
  <% end %>

  <div class="flex min-w-0 flex-1 items-center gap-2.5" data-testid="category-content">
    <% if category.subcategory? %>
      <span style="color: <%= category.color %>">
        <%= icon "corner-down-right", size: "sm", color: "current", class: "ml-2" %>
      </span>
    <% end %>

    <%= render partial: "categories/badge", locals: { category: category } %>

    <% if budget_category&.budgeted_spending.to_f > 0 %>
      <div class="flex items-center gap-2 ml-auto pl-4 shrink-0 w-40">
        <div class="grow h-1.5 rounded-full bg-surface-inset overflow-hidden">
          <div class="h-full rounded-full <%= budget_category.percent_of_budget_spent > 100 ? "bg-destructive" : "bg-success" %>" style="width: <%= [ budget_category.percent_of_budget_spent, 100 ].min %>%"></div>
        </div>
        <p class="text-xs text-secondary whitespace-nowrap privacy-sensitive">
          <%= budget_category.actual_spending_money.format(precision: 0) %> / <%= budget_category.budgeted_spending_money.format(precision: 0) %>
        </p>
      </div>
    <% end %>
  </div>

  <div class="shrink-0" data-testid="category-actions">
    <%= render DS::Menu.new do |menu| %>
      <% menu.with_item(variant: "link", text: t(".edit"), icon: "pencil", href: edit_category_path(category), data: { turbo_frame: :modal }) %>

      <% if has_transactions %>
        <% menu.with_item(variant: "link", text: t(".delete"), icon: "trash-2", href: new_category_deletion_path(category), destructive: true, data: { turbo_frame: :modal }) %>
      <% else %>
        <% menu.with_item(variant: "button", text: t(".delete"), icon: "trash-2", href: category_path(category), method: :delete) %>
      <% end %>
    <% end %>
  </div>
</div>
