<%# locals: (entry:) %>
<%= link_to entry_path(entry),
    data: { turbo_frame: "drawer", action: "click->command-palette#close", command_palette_target: "resultLink" },
    class: "flex items-center gap-3 px-2 py-2 rounded-lg hover:bg-surface-hover focus-visible:bg-surface-hover outline-none" do %>
  <%= render DS::FilledIcon.new(variant: :text, text: entry.name, size: "sm", rounded: true) %>
  <div class="min-w-0 grow">
    <p class="text-sm font-medium text-primary truncate"><%= entry.name %></p>
    <p class="text-xs text-secondary"><%= entry.account.name %> · <%= I18n.l(entry.date, format: :long) %></p>
  </div>
  <p class="text-sm font-medium text-primary shrink-0 privacy-sensitive"><%= format_money -entry.amount_money %></p>
<% end %>
